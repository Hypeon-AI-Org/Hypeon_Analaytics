# =============================================================================
# HypeOn Analytics V1 - Environment example
# Copy to .env and fill in values. Do not commit .env.
# BQ project/datasets come from Firestore per organization (no dataset fallback).
# Local dev: set API_KEY and VITE_API_KEY to the same value. See docs/LOCAL_DEV_QUICKSTART.md.
# =============================================================================

# ----- Required (backend) -----
API_KEY=your-api-key-for-x-api-key-header
# Local: ENV=dev. Production: ENV=production (rejects dev-local-secret).
ENV=dev
# Local: comma-separated localhost origins. Production: your frontend URL(s), e.g. https://app.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ----- Firebase (Auth + Firestore) -----
# Backend verifies tokens and reads Firestore (user + org BQ config, copilot_sessions).
# FIREBASE_PROJECT_ID must match the Firebase project that issues ID tokens (and where Firestore is enabled).
# Enable Cloud Firestore API in that project: https://console.cloud.google.com/apis/library/firestore.googleapis.com
# Local: can use ADC — run gcloud auth application-default login; leave unset.
# Cloud Run / CI: set path to service account key (or use workload identity).
# GOOGLE_APPLICATION_CREDENTIALS=path/to/firebase-service-account.json
# Firebase project (must match token audience and have Firestore enabled):
# FIREBASE_PROJECT_ID=your-firebase-project-id
# Only if using non-default Firestore database:
# FIRESTORE_DATABASE_ID=hypeon-analytics

# ----- Copilot: LLM (one of these) -----
# Claude preferred. Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key
# Used when ANTHROPIC_API_KEY is not set. Get key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key
# Optional: COPILOT_MAX_OUTPUT_TOKENS (default 2048), CLAUDE_MODEL, GEMINI_MODEL

# ----- Optional -----
# JWT_SECRET=
# Redis (omit = in-memory cache). Memorystore: redis://<PRIMARY_IP>:6379/0
# REDIS_URL=redis://localhost:6379/0
# Production: use INFO. Local dev: DEBUG is fine.
# LOG_LEVEL=INFO
# UVICORN_ACCESS_LOG=0
# AUDIT_STDOUT=1
# Production: set to your GCP project (Firebase/Firestore). Backend uses it when GOOGLE_APPLICATION_CREDENTIALS is set.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ----- Optional: BQ env (scripts / non-org flows only) -----
# App uses Firestore org config for BQ project/datasets; these are not used as fallback.
# BQ_PROJECT=your-app-gcp-project-id
# BQ_SOURCE_PROJECT=your-source-gcp-project-id
# BQ_LOCATION=europe-north2
# BQ_LOCATION_ADS=EU

# ----- Airflow / Cloud Composer (optional: cache refresh DAG) -----
# HYPEON_REPO_PATH=/home/airflow/gcs/dags/hypeon-analytics
# PYTHON=python
# REFRESH_CACHE_URL=https://your-api.example.com

# =============================================================================
# Frontend - use in frontend/.env or frontend/.env.local
# =============================================================================
# VITE_API_BASE=
# VITE_API_KEY=your-api-key-for-x-api-key-header
# Firebase Web config (Firebase Console > Project settings > Your apps)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
